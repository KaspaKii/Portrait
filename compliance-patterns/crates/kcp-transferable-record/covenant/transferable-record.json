    "span": "contract TransferableRecord(\n    byte[32] genesisRecordId,\n    int      genesisSeq,\n    byte[32] genesisControllerPk\n) {\n    byte[32] record_id    = genesisRecordId;\n    int      seq          = genesisSeq;\n    byte[32] controllerPk = genesisControllerPk;\n\n    // TR-3: ownership — the CURRENT controller must sign.\n    function checkOwnership(State[] prevStates, sig s) {\n        require(checkSig(s, prevStates[0].controllerPk));\n    }\n\n    // TR-1: seq must increment by exactly 1.\n    function checkSeq(State[] prevStates, State[] newStates) {\n        require(newStates[0].seq == prevStates[0].seq + 1);\n    }\n\n    // TR-2: record_id must be preserved.\n    function checkRecordId(State[] prevStates, State[] newStates) {\n        require(newStates[0].record_id == prevStates[0].record_id);\n    }\n\n    // Single-input single-output transfer transition.\n    // from=1, to=1: exactly one covenant input and one covenant output.\n    // The new controllerPk is unconstrained — it is set by the caller in newStates.\n    #[covenant(binding = cov, from = 1, to = 1)]\n    function transfer(State[] prevStates, State[] newStates, sig s) {\n        checkOwnership(prevStates, s);\n        checkSeq(prevStates, newStates);\n        checkRecordId(prevStates, newStates);\n    }\n}",
    "name_span": "TransferableRecord"
