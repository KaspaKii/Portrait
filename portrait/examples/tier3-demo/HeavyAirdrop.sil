pragma silverscript ^0.1.0;

// Generated by portrait build
contract HeavyAirdrop(int max_ins, int max_outs, int start) {
    int v = start;

    #[covenant(binding = cov, from = max_ins, to = 1, mode = transition)]
    function settle(State[] prev_states, int amount, byte[32] proof_cov_id) : (State) {
        require(proof_cov_id == OpInputCovenantId(0));
        return({ v: prev_states[0].v - amount });
    }
}
