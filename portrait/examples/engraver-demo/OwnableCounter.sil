pragma silverscript ^0.1.0;

// Generated by portrait build
contract OwnableCounter(int max_ins, int max_outs, pubkey owner, int count) {
    pubkey owner = owner;
    int count = count;

    #[covenant(binding = cov, from = max_ins, to = 1, mode = transition)]
    function increment(State[] prev_states, sig auth) : (State) {
        require(checkSig(auth, prev_states[0].owner));
        return({ owner: prev_states[0].owner, count: prev_states[0].count + 1 });
    }
}
