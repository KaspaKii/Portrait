pragma silverscript ^0.1.0;

// Generated by portrait build
contract SimpleToken(int max_ins, int max_outs, int start) {
    int balance = start;

    #[covenant(binding = cov, from = max_ins, to = 1, mode = transition)]
    function transfer(State[] prev_states, int amount) : (State) {
        return({ balance: prev_states[0].balance - amount });
    }
}
