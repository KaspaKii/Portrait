pragma silverscript ^0.1.0;

// Generated by portrait build
contract VestingWallet(int max_ins, int max_outs, int start) {
    int released = start;

    #[covenant(binding = cov, from = max_ins, to = 1, mode = transition)]
    function release(State[] prev_states, int amount) : (State) {
        return({ released: prev_states[0].released + amount });
    }
}
