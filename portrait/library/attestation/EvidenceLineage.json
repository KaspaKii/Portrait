        "span": "#[covenant(binding = cov, from = max_ins, to = 1, mode = transition)]\n    function attest(State[] prev_states, sig auth, byte[32] next_commit, int next_class, int next_t_bucket) : (State) {\n        require(checkSig(auth, issuer));\n        require(next_class >= 0);\n        require(next_t_bucket >= prev_states[0].t_bucket);\n        require(next_t_bucket <= prev_states[0].t_bucket + window);\n        return({ seq: prev_states[0].seq + 1, subject: prev_states[0].subject, commit: next_commit, t_bucket: next_t_bucket, event_class: next_class });\n    }",
