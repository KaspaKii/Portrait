        "span": "#[covenant(binding = cov, from = max_ins, to = 1, mode = transition)]\n    function spend(State[] prev_states, sig auth_a, sig auth_b, int amount) : (State) {\n        require(checkSig(auth_a, prev_states[0].signer_a));\n        require(checkSig(auth_b, prev_states[0].signer_b));\n        require(amount >= 0);\n        require(amount <= prev_states[0].balance);\n        return({ signer_a: prev_states[0].signer_a, signer_b: prev_states[0].signer_b, balance: prev_states[0].balance - amount });\n    }",
        "name_span": "spend",
        "body_span": "require(checkSig(auth_a, prev_states[0].signer_a));\n        require(checkSig(auth_b, prev_states[0].signer_b));\n        require(amount >= 0);\n        require(amount <= prev_states[0].balance);\n        return({ signer_a: prev_states[0].signer_a, signer_b: prev_states[0].signer_b, balance: prev_states[0].balance - amount });"
