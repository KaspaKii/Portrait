        "span": "#[covenant(binding = cov, from = max_ins, to = 1, mode = transition)]\n    function withdraw(State[] prev_states, sig auth, int amount) : (State) {\n        require(checkSig(auth, prev_states[0].recipient));\n        require(amount >= 0);\n        require(prev_states[0].supply + amount <= prev_states[0].total);\n        return({ recipient: prev_states[0].recipient, total: prev_states[0].total, start: prev_states[0].start, duration: prev_states[0].duration, supply: prev_states[0].supply + amount });\n    }",
