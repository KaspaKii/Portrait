        "span": "#[covenant(binding = cov, from = max_ins, to = 1, mode = transition)]\n    function transfer(State[] prev_states, sig auth, int amount) : (State) {\n        require(checkSig(auth, prev_states[0].owner));\n        require(amount >= 0);\n        require(amount <= prev_states[0].from_balance);\n        return({ from_balance: prev_states[0].from_balance - amount, to_balance: prev_states[0].to_balance + amount, owner: prev_states[0].owner });\n    }",
